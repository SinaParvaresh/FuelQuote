exports[`Login if render matches snapshot 1`] = `
<div
  className="login-background"
>
  <form
    action="profileManagement"
    className="Login"
    id="login-form"
    onSubmit={[Function]}
  >
    <h1>
      LOGIN
    </h1>
    <br />
    <div
      className="input-group mb-3"
    >
      <div
        className="input-group-prepend"
      >
        <label
          className="input-group-text"
          htmlFor="usernm"
          id="basic-addon1"
        >
          Username
        </label>
      </div>
      <input
        aria-describedby="basic-addon1"
        aria-label="Username"
        className="form-control"
        id="usernm"
        onChange={[Function]}
        placeholder="user@example.com"
        required={true}
        type="text"
        value=""
      />
    </div>
    <div
      className="input-group mb-3"
    >
      <div
        className="input-group-prepend"
      >
        <label
          className="input-group-text"
          htmlFor="passwrd"
          id="basic-addon1"
        >
          Password
        </label>
      </div>
      <input
        aria-describedby="basic-addon1"
        aria-label="Username"
        className="form-control"
        id="passwrd"
        onChange={[Function]}
        placeholder="********"
        required={true}
        type="password"
      />
    </div>
    <div>
      <button
        className="btn btn-primary"
        disabled={true}
        type="submit"
      >
         Submit 
      </button>
    </div>
    <br />
    <a
      href="/registration"
